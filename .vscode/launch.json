{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Streamlit: Run (Dry Run Mode)",
            "type": "python",
            "request": "launch",
            "module": "streamlit",
            "args": ["run", "src/web/frontend.py"],
            "env": {
                "MISTRAL_DRY_RUN": "1"
            },
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "RunPod: Deploy (Debug Mode)",
            "type": "python",
            "request": "launch",
            "module": "src.main",
            "args": ["deploy", "--branch", "master"],
            "envFile": "${workspaceFolder}/.env",
            "console": "integratedTerminal",
            "justMyCode": true,
        },
    ]
}

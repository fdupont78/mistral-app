{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Streamlit: Run (Dry Run Mode)",
            "type": "python",
            "request": "launch",
            "module": "streamlit",
            "args": ["run", "src/web/frontend.py"],
            "env": {
                "MISTRAL_DRY_RUN": "1"
            },
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Streamlit: Run (Normal Mode)",
            "type": "python",
            "request": "launch",
            "module": "streamlit",
            "args": ["run", "src/web/frontend.py"],
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "CLI: Chat (Dry Run)",
            "type": "python",
            "request": "launch",
            "module": "src.main",
            "args": ["chat", "--dry-run"],
            "console": "integratedTerminal"
        },
        {
            "name": "CLI: List Conversations",
            "type": "python",
            "request": "launch",
            "module": "src.main",
            "args": ["list"],
            "console": "integratedTerminal"
        },
        {
            "name": "RunPod: Deploy (Current Branch)",
            "type": "python",
            "request": "launch",
            "module": "src.main",
            "args": ["deploy", "--branch", "${input:branch}"],
            "env": {
                "RUNPOD_API_KEY": "${env:RUNPOD_API_KEY}",
                "RUNPOD_TEMPLATE_ID": "${env:RUNPOD_TEMPLATE_ID}"
            },
            "console": "integratedTerminal",
            "justMyCode": false,
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "name": "RunPod: Deploy (Debug Mode)",
            "type": "python",
            "request": "launch",
            "module": "src.main",
            "args": ["deploy", "--branch", "master"],
            "env": {
                "RUNPOD_API_KEY": "${env:RUNPOD_API_KEY}",
                "RUNPOD_TEMPLATE_ID": "${env:RUNPOD_TEMPLATE_ID}"
            },
            "console": "integratedTerminal",
            "justMyCode": true,
            "stopOnEntry": false,
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "name": "RunPod: Deploy (From .env file)",
            "type": "python",
            "request": "launch",
            "module": "src.main",
            "args": ["deploy", "--branch", "master"],
            "envFile": "${workspaceFolder}/.env",
            "console": "integratedTerminal",
            "justMyCode": false,
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        }
    ]
}

{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Streamlit: Run (Dry Run Mode)",
            "type": "python",
            "request": "launch",
            "module": "streamlit",
            "args": ["run", "src/web/frontend.py"],
            "env": {
                "MISTRAL_DRY_RUN": "1"
            },
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Streamlit: Run (Normal Mode)",
            "type": "python",
            "request": "launch",
            "module": "streamlit",
            "args": ["run", "src/web/frontend.py"],
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "CLI: Chat (Dry Run)",
            "type": "python",
            "request": "launch",
            "module": "src.main",
            "args": ["chat", "--dry-run"],
            "console": "integratedTerminal"
        },
        {
            "name": "CLI: List Conversations",
            "type": "python",
            "request": "launch",
            "module": "src.main",
            "args": ["list"],
            "console": "integratedTerminal"
        }
    ]
}
